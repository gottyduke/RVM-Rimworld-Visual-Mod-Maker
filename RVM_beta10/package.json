{
  "name": "rimworld-visual-mod-maker-v24",
  "version": "0.24.0",
  "private": true,
  "description": "Visual no-code RimWorld HAR alien race mod maker Beta 1.0 prototype",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "web": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "desktop": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && electron .\""
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "jszip": "^3.10.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xmlbuilder2": "^3.1.1",
    "zod": "^3.24.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
